# Copy to .env for local dev. In Azure these become App Service "Application settings".

# Anthropic API key — server-side only, NEVER in the front end.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Model. Sonnet is the cost/latency-appropriate default for a high-volume staff bot.
MODEL=claude-sonnet-4-6

# Azure Table Storage (holds the central Q&A log).
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Comma-separated emails allowed to see the review log (the admins).
ADMIN_USERS=cormac.heffernan@finplex.com.au

PORT=3000
